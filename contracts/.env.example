# Deployer wallet private key (generated via: npm run wallet:generate)
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...

# Polygonscan API key for contract verification
# Get from: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=

# Optional: custom Polygon mainnet RPC (Alchemy/Infura recommended for production)
# Defaults to https://polygon-rpc.com if not set
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
