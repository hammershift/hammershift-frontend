# Velocity Markets Frontend - Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# NextAuth.js Configuration
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# ============================================
# Database Configuration
# ============================================
MONGODB_URI=your_mongodb_connection_string_here

# ============================================
# Analytics & Marketing
# ============================================

# Customer.io - Marketing automation and email campaigns
CUSTOMERIO_SITE_ID=your_customerio_site_id_here
CUSTOMERIO_API_KEY=your_customerio_api_key_here

# PostHog - Product analytics and event tracking
POSTHOG_API_KEY=your_posthog_api_key_here
POSTHOG_HOST=https://app.posthog.com

# ============================================
# Payment Processing
# ============================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# ============================================
# Optional: Error Tracking
# ============================================
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# ============================================
# Web3 / Polygon Configuration
# ============================================
# WalletConnect Project ID - Get from https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Polygon RPC URLs (optional - defaults provided)
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-rpc.com
NEXT_PUBLIC_POLYGON_MUMBAI_RPC_URL=https://rpc-mumbai.maticvigil.com
